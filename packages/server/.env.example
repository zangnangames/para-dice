# ── 데이터베이스 ───────────────────────────────────────────────
# Railway PostgreSQL 플러그인이 자동으로 주입함
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Redis ─────────────────────────────────────────────────────
# Railway Redis 플러그인이 자동으로 주입함
REDIS_URL="redis://default:password@host:6379"

# ── 인증 ──────────────────────────────────────────────────────
JWT_SECRET="여기에-랜덤한-긴-문자열-입력"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URI="https://your-railway-app.railway.app/auth/google/callback"

# ── 클라이언트 URL ─────────────────────────────────────────────
# Vercel 배포 URL (CORS 허용)
CLIENT_URL="https://your-vercel-app.vercel.app"

# ── 서버 포트 ──────────────────────────────────────────────────
# Railway가 PORT를 자동으로 주입함 (기본 3001)
PORT=3001
